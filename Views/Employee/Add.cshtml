@using EMS.Models.ViewModels
@model DashboardViewModel

@if (TempData["msg"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["msg"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<style>
    /* ================= PAGE BANNER ================= */
    .page-banner {
        background: linear-gradient(135deg, #1e3c72, #2a5298);
        color: white;
        padding: 25px 30px;
        border-radius: 18px;
        margin-bottom: 25px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    }

        .page-banner h3 {
            font-weight: 600;
            margin: 0;
        }

    .page-icon {
        font-size: 28px;
        background: rgba(255,255,255,0.2);
        padding: 12px;
        border-radius: 50%;
        margin-right: 15px;
    }

    /* ================= CARD ================= */
    .custom-card {
        border-radius: 18px;
        border: none;
        box-shadow: 0 8px 25px rgba(0,0,0,0.08);
    }

    /* ================= TABLE ================= */
    #employeeTable thead {
        background: linear-gradient(135deg, #1e3c72, #2a5298);
        color: white;
    }

    #employeeTable tbody tr:hover {
        background-color: #f2f6ff;
    }

    .emp-img {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        object-fit: cover;
        border: 2px solid #2a5298;
        margin-right: 8px;
    }

    /* ================= FORM ================= */
    .form-control, .form-select {
        border-radius: 10px;
        transition: 0.3s;
    }

        .form-control:focus, .form-select:focus {
            border-color: #2a5298;
            box-shadow: 0 0 6px rgba(42,82,152,0.3);
        }

    .btn-primary {
        background: linear-gradient(135deg, #1e3c72, #2a5298);
        border: none;
    }

        .btn-primary:hover {
            opacity: 0.9;
        }

    #searchInput {
        border-radius: 25px;
        padding-left: 15px;
    }
</style>

<!-- ================= PAGE HEADER ================= -->
<div class="page-banner d-flex justify-content-between align-items-center">
    <div class="d-flex align-items-center">
        <div class="page-icon">
            <i class="fa-solid fa-users"></i>
        </div>
        <div>
            <h3>Employee Management</h3>
            <small>Manage employees, departments & records</small>
        </div>
    </div>

    <div class="text-end">
        <div>Total Employees</div>
        <div class="fw-bold fs-4">@Model.Employees.Count</div>
    </div>
</div>

<div class="container-fluid">
    <div class="row">

        <!-- ================= LEFT : EMPLOYEE LIST ================= -->
        <div class="col-md-7">
            <div class="card custom-card">
                <div class="card-body">

                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="mb-0">Company Employees</h5>
                        <input type="text" id="searchInput" class="form-control w-25"
                               placeholder="Search employee...">
                    </div>

                    <table class="table align-middle mt-2" id="employeeTable">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Name</th>
                                <th>Department</th>
                                <th>Contact</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var ITEM in Model.Employees)
                            {
                                <tr>
                                    <td>@ITEM.EmployeeId</td>
                                    <td>
                                        <img src="@ITEM.PhotoPath" class="emp-img" />
                                        @ITEM.FirstName
                                    </td>
                                    <td>@ITEM.Department.DepartmentName</td>
                                    <td>
                                        @ITEM.Phone <br />
                                        <small>@ITEM.Email</small>
                                    </td>
                                    <td>
                                        <a asp-action="Add" asp-route-id="@ITEM.EmployeeId"
                                           class="btn btn-sm btn-primary">
                                            <i class="fa fa-edit"></i>
                                        </a>

                                        <a asp-action="Delete" asp-route-id="@ITEM.EmployeeId"
                                           class="btn btn-sm btn-danger">
                                            <i class="fa fa-trash"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>

                </div>
            </div>
        </div>

        <!-- ================= RIGHT : ADD EMPLOYEE FORM ================= -->
        <div class="col-md-5">
            <div class="card custom-card">
                <div class="card-header text-white"
                     style="background: linear-gradient(135deg, #1e3c72, #2a5298); border-radius:18px 18px 0 0;">
                    <h5 class="mb-0">
                        @(Model.NewEmployee.EmployeeId == 0 ? "Add Employee" : "Update Employee")
                    </h5>
                </div>

                <div class="card-body">
                    <form asp-action="Add" method="post" enctype="multipart/form-data">
                        <input type="hidden" asp-for="NewEmployee.EmployeeId" />

                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3">
                        </div> <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="NewEmployee.FirstName" class="form-label">First Name</label>
                                <input asp-for="NewEmployee.FirstName" class="form-control" />
                                <span asp-validation-for="NewEmployee.FirstName" class="text-danger">
                                </span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="NewEmployee.LastName" class="form-label">Last Name</label>
                                <input asp-for="NewEmployee.LastName" class="form-control" />
                                <span asp-validation-for="NewEmployee.LastName" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="NewEmployee.Email" class="form-label">Email</label>
                                <input asp-for="NewEmployee.Email" class="form-control" />
                                <span asp-validation-for="NewEmployee.Email" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="NewEmployee.Phone" class="form-label">Phone</label>
                                <input asp-for="NewEmployee.Phone" class="form-control" />
                                <span asp-validation-for="NewEmployee.Phone" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="NewEmployee.AadhaarNumber" class="form-label">Aadhaar Number</label>
                                <input asp-for="NewEmployee.AadhaarNumber" class="form-control" />
                                <span asp-validation-for="NewEmployee.AadhaarNumber" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="NewEmployee.PanNumber" class="form-label">Pan Number</label>
                                <input asp-for="NewEmployee.PanNumber" class="form-control" />
                                <span asp-validation-for="NewEmployee.PanNumber" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="NewEmployee.DateOfBirth" class="form-label">Date Of Birth</label>
                                <input asp-for="NewEmployee.DateOfBirth" type="date" class="form-control" />
                                <span asp-validation-for="NewEmployee.DateOfBirth" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="NewEmployee.Gender" class="form-label">Gender</label>
                                <select asp-for="NewEmployee.Gender" class="form-select">
                                    <option value="">-- Select Gender --</option>
                                    <option>Male</option>
                                    <option>Female</option>
                                    <option>Other</option>
                                </select>
                                <span asp-validation-for="NewEmployee.Gender" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="NewEmployee.DepartmentId" class="form-label">Department</label>
                                <select asp-for="NewEmployee.DepartmentId" asp-items="ViewBag.Departments" class="form-control">
                                    <option value="">-- Select Department --</option>
                                </select><br />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="NewEmployee.PhotoPath"
                                       class="form-label">Upload Profile</label>
                                <input asp-for="NewEmployee.PhotoPath" name="Photo" type="file" class="form-control" placeholder="Upload Photo" />
                                <span asp-validation-for="NewEmployee.PhotoPath" class="text-danger"></span>
                            </div>
                        </div>


                        <div class="mt-4 text-end">
                            <button type="submit"
                                    class="btn btn-primary">
                                @(Model.NewEmployee.EmployeeId == 0 ? "Save" : "Update")
                            </button>
                        </div>

                    </form>
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        document.getElementById("searchInput").addEventListener("input", function () {
            let filter = this.value.toLowerCase();
            let rows = document.querySelectorAll("#employeeTable tbody tr");

            rows.forEach(function (row) {
                let text = row.innerText.toLowerCase();
                row.style.display = text.indexOf(filter) > -1 ? "" : "none";
            });
        });
    </script>
}