@using EMS.Models.ViewModels
@model DashboardViewModel
@{
    Layout = "/Views/Shared/_Layout.cshtml";
}

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
@if (TempData["app"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["app"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["rej"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["rej"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<style>
    :root {
        --primary-gradient: linear-gradient(135deg,#1e3c72,#2a5298);
        --primary-color: #2a5298;
    }

    .page-banner {
        background: linear-gradient(135deg, #1e3c72, #2a5298);
        color: white;
        padding: 25px 30px;
        border-radius: 18px;
        margin-bottom: 25px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    }

    .icon-btn {
        width: 32px;
        height: 32px;
        padding: 0;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
    }

    .page-banner h4 {
        font-weight: 600;
        margin: 0;
    }

    .header-icon {
        background: rgba(255,255,255,0.15);
        padding: 8px 10px;
        border-radius: 10px;
        font-size: 18px;
    }

    .header-subtitle {
        opacity: 0.85;
        font-size: 14px;
    }

    .total-label {
        font-size: 13px;
        opacity: 0.85;
    }

    .total-number {
        font-size: 28px;
        font-weight: 700;
    }

    /* ===== STAT CARDS ===== */
    .stat-card {
        background: var(--primary-gradient);
        border-radius: 16px;
        padding: 20px;
        color: white;
        box-shadow: 0 8px 25px rgba(0,0,0,0.08);
        transition: 0.3s;
    }

        .stat-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 15px 35px rgba(0,0,0,0.15);
        }

    /* ===== CONTENT CARDS ===== */
    .custom-card {
        border-radius: 18px;
        border: none;
        box-shadow: 0 8px 25px rgba(0,0,0,0.08);
    }

    /* ===== TABLE ===== */
    .custom-table thead {
        background: var(--primary-gradient);
        color: white;
    }

    /* ===== BUTTON ===== */
    .btn-theme {
        background: var(--primary-gradient);
        border: none;
        color: white;
    }

        .btn-theme:hover {
            opacity: 0.9;
            color: white;
        }



    .dashboard-card {
        background: var(--primary-gradient);
        border-radius: 18px;
        padding: 25px 30px;
        color: white;
        position: relative;
        overflow: hidden;
        box-shadow: 0 8px 25px rgba(0,0,0,0.1);
        transition: 0.3s;
        min-height: 110px;
    }

        .dashboard-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 35px rgba(0,0,0,0.15);
        }

        .dashboard-card h2 {
            font-weight: 700;
            font-size: 32px;
            margin: 0;
        }

        .dashboard-card p {
            margin: 5px 0 0;
            opacity: 0.9;
            font-size: 15px;
        }

        .dashboard-card .card-icon {
            position: absolute;
            right: 25px;
            top: 20px;
            font-size: 45px;
            opacity: 0.15;
        }
</style>

<div class="container-fluid p-4">
    <div class="page-banner d-flex justify-content-between align-items-center">

        <!-- LEFT SIDE -->
        <div>
            <h4 class="mb-1 d-flex align-items-center gap-2">
                <span class="header-icon">
                    <i class="fa-solid fa-chart-line card-icon"></i>
                </span>
                Dashboard Overview
            </h4>

        </div>



    </div>
    <br />

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="row g-3">
                <div class="col-md-6" id="emp">
                    <div class="dashboard-card">
                        <h2 class="counter" data-target="@Model.Employees.Count">0</h2>
                        <p>Total Employees</p>
                        <i class="fa-solid fa-users card-icon"></i>
                    </div>
                </div>

                <div class="col-md-6" id="Ptoday">
                    <div class="dashboard-card">
                        <h2 class="counter" data-target="@Model.PresentToday">0</h2>
                        <p>Present Today</p>
                        <i class="fa-solid fa-user-check card-icon"></i>
                    </div>
                </div>


                <div class="col-md-6" id="Lreq">
                    <a asp-action="Dashboard" asp-route-am="lr" style="text-decoration:none;color:white" class="p-0">
                        <div class="dashboard-card">
                            <h2 class="counter" data-target="@Model.LeaveRequest">0</h2>
                            <p>Leave Requests</p>
                            <i class="fa-solid fa-calendar-check card-icon"></i>
                        </div>
                    </a>
                </div>


                <div class="col-md-6" id="leave">
                    <div class="dashboard-card">
                        <h2 class="counter" data-target="0">0</h2>
                        <p>On Leave</p>
                        <i class="fa-solid fa-user-clock card-icon"></i>
                    </div>
                </div>

                <div class="col-md-6" id="Rpres">
                      <a asp-action="Dashboard" asp-route-am="ar" style="text-decoration:none;color:white" class="p-0">
                    <div class="dashboard-card">
                        <h2 class="counter" data-target="@Model.PendingRequests"></h2>
                        <p>Presenty Requests</p>
                        <i class="fa-solid fa-file-signature card-icon"></i>
                    </div>
                    </a>
                </div>

                <div class="col-md-6" id="Ptask">
                    <div class="dashboard-card">
                        <h2 class="counter" data-target="0">0</h2>
                        <p>Pending Tasks</p>
                        <i class="fa-solid fa-hourglass-half card-icon"></i>
                    </div>
                </div>

                <div class="col-md-6" id="task">
                    <div class="dashboard-card">
                        <h2 class="counter" data-target="0">0</h2>
                        <p>My Tasks</p>
                        <i class="fa-solid fa-list-check card-icon"></i>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="dashboard-card" id="pro">
                        <h2 class="counter" data-target="0">0</h2>
                        <p>My Projects</p>
                        <i class="fa-solid fa-folder-open card-icon"></i>
                    </div>
                </div>
            </div>
        </div>
        @if (User.IsInRole("Admin"))
        {
            <div class="col-lg-8">
                @{
                    string s = "ar";
                    if (ViewBag.am != null)
                    {
                        s = ViewBag.am;
                    }

                    switch (s)
                    {
                        case "ar":
                            <div class="card custom-card">
                                <div class="card-body">

                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <h5 class="mb-0">Presenty Request</h5>
                                        <input type="text" id="searchInput" class="form-control w-25"
                                               placeholder="Search employee...">
                                    </div>

                                    <table class="table align-middle mt-2" id="employeeTable">
                                        <thead>
                                            <tr>
                                                <th>ID</th>
                                                <th>Name</th>

                                                <th>Punch In</th>
                                                <th>Action</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @if (Model?.empAttendanceViewModel?.list?.Any() == true)
                                            {
                                                @foreach (var ITEM in Model.empAttendanceViewModel.list)
                                                {
                                                    <tr>
                                                        <td>@ITEM.emp1.EmployeeId</td>
                                                        <td>
                                                            @ITEM.emp1.FirstName @ITEM.emp1.LastName
                                                        </td>

                                                        <td>
                                                            @ITEM.presenty.PunchIn
                                                        </td>
                                                        <td>

                                                            <!-- APPROVE ICON -->
                                                            <form asp-controller="Attendance"
                                                                  asp-action="Approve"
                                                                  method="post"
                                                                  class="d-inline">

                                                                <input type="hidden"
                                                                       name="id"
                                                                       value="@ITEM.presenty.Id" />

                                                                <button type="submit"
                                                                        class="btn btn-sm btn-success"
                                                                        title="Approve">
                                                                    <i class="fa-solid fa-check"></i>
                                                                </button>

                                                            </form>


                                                            <!-- REJECT ICON -->
                                                            <form asp-controller="Attendance"
                                                                  asp-action="Reject"
                                                                  method="post"
                                                                  class="d-inline">

                                                                <input type="hidden"
                                                                       name="id"
                                                                       value="@ITEM.presenty.Id" />

                                                                <button type="submit"
                                                                        class="btn btn-sm btn-danger"
                                                                        title="Reject">
                                                                    <i class="fa-solid fa-xmark"></i>
                                                                </button>

                                                            </form>

                                                        </td>
                                                    </tr>
                                                }
                                            }

                                            else
                                            {
                                                <tr>
                                                    <p class="alert-danger text-danger"> No Data Found</p>
                                                </tr>

                                            }
                                        </tbody>

                                    </table>

                                </div>
                            </div>
                            break;

                        case "lr":
                            <div class="card custom-card">
                                <div class="card-body">

                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <h5 class="mb-0">Leave Request</h5>
                                        <input type="text" id="searchInput" class="form-control w-25"
                                               placeholder="Search employee...">
                                    </div>

                                    <table class="table align-middle mt-2" id="employeeTable">
                                        <thead>
                                            <tr>
                                                <th>ID</th>
                                                <th>Name</th>

                                                <th>From Date</th>
                                                <th>To Date</th>
                                                <th>Reason</th>

                                                <th>Action</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @if (Model?.empAttendanceViewModel?.Leavelist?.Any() == true)
                                            {
                                                @foreach (var ITEM in Model.empAttendanceViewModel.Leavelist)
                                                {
                                                    <tr>
                                                        <td>@ITEM.emp2.EmployeeId</td>
                                                        <td>
                                                            @ITEM.emp2.FirstName @ITEM.emp2.LastName
                                                        </td>

                                                        <td>
                                                            @ITEM.leave.Fromdate
                                                        </td>
                                                        <td>
                                                            @ITEM.leave.Todate
                                                        </td>
                                                        <td>
                                                            @ITEM.leave.Reason
                                                        </td>
                                                        <td>

                                                            <!-- APPROVE ICON -->
                                                            <form asp-controller="Attendance"
                                                                  asp-action="LeaveApprove"
                                                                  method="post"
                                                                  class="d-inline">

                                                                <input type="hidden"
                                                                       name="id"
                                                                       value="@ITEM.leave.Id" />

                                                                <button type="submit"
                                                                        class="btn btn-sm btn-success"
                                                                        title="Approve">
                                                                    <i class="fa-solid fa-check"></i>
                                                                </button>

                                                            </form>


                                                            <!-- REJECT ICON -->
                                                            <form asp-controller="Attendance"
                                                                  asp-action="LeaveReject"
                                                                  method="post"
                                                                  class="d-inline">

                                                                <input type="hidden"
                                                                       name="id"
                                                                       value="@ITEM.leave.Id" />

                                                                <button type="submit"
                                                                        class="btn btn-sm btn-danger"
                                                                        title="Reject">
                                                                    <i class="fa-solid fa-xmark"></i>
                                                                </button>

                                                            </form>

                                                        </td>
                                                    </tr>
                                                }
                                            }

                                            else
                                            {
                                                <tr>
                                                    <p class="alert-danger text-danger"> No Data Found</p>
                                                </tr>

                                            }
                                        </tbody>

                                    </table>

                                </div>
                            </div>
                            break;


                    }
                }
            </div>
        }
    </div>
</div>

@section Scripts {

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>

        // ===== ANIMATED COUNTER =====
        const counters = document.querySelectorAll('.counter');

        counters.forEach(counter => {
            counter.innerText = '0';

            const updateCounter = () => {
                const target = +counter.getAttribute('data-target');
                const current = +counter.innerText;

                const increment = Math.ceil(target / 100);

                if (current < target) {
                    counter.innerText = current + increment;
                    setTimeout(updateCounter, 30);
                } else {
                    counter.innerText = target;
                }
            };

            updateCounter();
        });
    </script>

}