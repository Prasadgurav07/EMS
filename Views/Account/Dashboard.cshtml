@using EMS.Models.ViewModels
@model DashboardViewModel
@{
    Layout = "/Views/Shared/_Layout.cshtml";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Employee Management Dashboard</title>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <style>
        body {
            background-color: #f4f6f9;
        }

        .card-box {
            border-radius: 12px;
            color: white;
        }

    </style>
</head>
<body>

    <div class="container-fluid p-4">

        

        <!-- Top Cards -->
        <div class="row g-3">
            <div class="col-md-2">
                <div class="card card-box bg-info p-3">
                    <h5>Total Employees</h5>
                    <h2>@Model.Employees.Count</h2>
                </div>
            </div>
            <div class="col-md-2 ">
                <div class="card card-box bg-primary p-3">
                    <h5>Present Today</h5>
                    <h2>95</h2>
                </div>
            </div>
            <div class="col-md-2 ">
                <div class="card card-box bg-warning p-3">
                    <h5>On Leave</h5>
                    <h2>15</h2>
                </div>
            </div>
            <div class="col-md-2 ">
                <div class="card card-box bg-danger p-3">
                    <h5>Leave Requests</h5>
                    <h2>5</h2>
                </div>
            </div>
            <div class="col-md-2 ">
                <div class="card card-box bg-success p-3">
                    <h5>Presenty Requests</h5>
                    <h2>5</h2>
                </div>
            </div>
        </div>

        <!-- Chart & Leave Requests -->
        <div class="row mt-4">
            <div class="col-md-7">
                <div class="card p-3">
                    <h5>Attendance Overview</h5>
                    <canvas id="attendanceChart"></canvas>
                </div>
            </div>

            <div class="col-md-5">
                <div class="card p-3">
                    <h5>Leave Requests</h5>
                    <table class="table table-bordered mt-2">
                        <thead class="table-light">
                            <tr>
                                <th>Employee</th>
                                <th>Date</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>Rahul Sharma</td>
                                <td>02-Feb-2025</td>
                                <td>
                                    <button class="btn btn-success btn-sm">Approve</button>
                                    <button class="btn btn-danger btn-sm">Reject</button>
                                </td>
                            </tr>
                            <tr>
                                <td>Anita Verma</td>
                                <td>03-Feb-2025</td>
                                <td>
                                    <button class="btn btn-success btn-sm">Approve</button>
                                    <button class="btn btn-danger btn-sm">Reject</button>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Employee Table -->
        <div class="row mt-4">
            <div class="col-md-12">
                <div class="card p-3">
                    <h5>Employee List</h5>
                    <table class="table table-striped table-bordered mt-2">
                        <thead class="table-dark">
                            <tr>
                                <th>Emp ID</th>
                                <th>Name</th>
                                <th>Department</th>
                                <th>Role</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>101</td>
                                <td>Rahul Sharma</td>
                                <td>IT</td>
                                <td>Developer</td>
                                <td><span class="badge bg-success">Active</span></td>
                            </tr>
                            <tr>
                                <td>102</td>
                                <td>Anita Verma</td>
                                <td>HR</td>
                                <td>Manager</td>
                                <td><span class="badge bg-success">Active</span></td>
                            </tr>
                            <tr>
                                <td>103</td>
                                <td>Mohit Singh</td>
                                <td>Finance</td>
                                <td>Accountant</td>
                                <td><span class="badge bg-danger">Inactive</span></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

    </div>

    <script>
        const ctx = document.getElementById('attendanceChart');

        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: ['Present', 'Onleave', 'Leave Request', 'Presenty Request', 'Absent'],
                datasets: [{
                    label: 'Employees',
                    data: [95, 15, 5, 5 ,5],
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: { display: false }
                }
            }
        });
    </script>

</body>
</html>
