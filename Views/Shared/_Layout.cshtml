

@using Newtonsoft.Json
@using Microsoft.AspNetCore.Http



<!DOCTYPE html>
<html>
<head>
    <title>@ViewBag.Title - Admin</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet" />

    <style>
        body {
            background-color: #f4f6f9;
            font-family: "Segoe UI", sans-serif;
        }

        /* SIDEBAR */
        .sidebar {
            width: 240px;
            height: 100vh;
            position: fixed;
            left: 0;
            top: 0;
            background: linear-gradient(180deg, #1e3c72, #2a5298);
            color: #fff;
            box-shadow: 2px 0 8px rgba(0,0,0,0.1);
        }

        .sidebar-header {
            font-size: 22px;
            font-weight: 600;
            padding: 20px;
            text-align: center;
            border-bottom: 1px solid rgba(255,255,255,0.2);
            letter-spacing: 1px;
        }

        .sidebar-item {
            display: flex;
            align-items: center;
            padding: 12px 20px;
            color: #fff;
            text-decoration: none;
            font-size: 15px;
            transition: all 0.3s ease;
        }

            .sidebar-item i {
                font-size: 16px;
                margin-right: 10px;
            }

            .sidebar-item:hover {
                background: rgba(255,255,255,0.15);
                color: #fff;
            }

            .sidebar-item.active {
                background: rgba(255,255,255,0.25);
                font-weight: 600;
                border-left: 4px solid #ffc107;
            }

        /* CONTENT */
        .content {
            margin-left: 240px;
            min-height: 100vh;
        }

        /* TOPBAR */
        .topbar {
            background: #ffffff;
            border-bottom: 1px solid #ddd;
            padding: 23px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

            .topbar .title {
                font-size: 18px;
                font-weight: 600;
                color: #2c3e50;
            }

            .topbar .user {
                color: #2c3e50;
                font-weight: 500;
            }

        .container-fluid {
            padding: 25px;
        }
    </style>
</head>
<body>

    <!-- SIDEBAR -->
    <div class="sidebar">
        <div class="sidebar-header">
            CuteHR
        </div>

        @{
            var currentPath = Context.Request.Path.ToString().ToLower();

            for (int i = 0; i < ViewBag.Features.Items.Count; i += 2)
            {
                var link = ViewBag.Features.Items[i + 1].ToString().ToLower();
                var text = ViewBag.Features.Items[i].ToString();

                var isActive = currentPath.Contains(link.ToLower()) ? "active" : "";
                <a href="@ViewBag.Features.Items[i + 1]" class="sidebar-item @isActive">
                    <i class="bi bi-speedometer2"></i>
                    <span>@text</span>
                </a>
            }
        }


    </div>

    <!-- CONTENT -->
    <div class="content">

        <!-- TOPBAR -->
        <div class="topbar">
            <div class="title">Admin Dashboard</div>

            <div class="user d-flex align-items-center">

                @if (!string.IsNullOrEmpty(@ViewBag.photo))
                {
                    <img src="@ViewBag.photo" width="35" height="35"
                         style="border-radius:50%; object-fit:cover; margin-right:8px;" />
                }
                else
                {
                    <i class="bi bi-person-circle me-2 fs-4"></i>
                }

                <span>Welcome, @ViewBag.name</span>
            </div>

        </div>

        <!-- PAGE CONTENT -->
        <div class="container-fluid">
            @RenderBody()
        </div>
    </div>
    @RenderSection("Scripts", required: false)
   
</body>
</html>
